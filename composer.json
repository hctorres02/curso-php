{
    "require": {
        "php": ">=8.2"
    },
    "autoload": {
        "files": ["src/helpers.php"],
        "psr-4": {}
    },
    "require-dev": {
        "pestphp/pest": "^3.7",
        "byjg/migration-cli": "^5.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "migrate": [
            "@putenv MIGRATE_PATH=./database",
            "@putenv MIGRATE_CONNECTION=sqlite://./database/database.sqlite",
            "./vendor/bin/migrate"
        ]
    }
}
